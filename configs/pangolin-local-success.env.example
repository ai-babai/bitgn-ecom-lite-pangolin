# Successful Pangolin-loop preset for local/non-leaderboard ECOM runs.
# Copy values into your shell or source this file after replacing the model/base URL.

# Backbone and model endpoint. The endpoint must be OpenAI Responses API compatible.
AGENT_BACKBONE=pangolin_loop
NATIVE_PANGOLIN_BASE_URL=http://127.0.0.1:8000/v1
NATIVE_PANGOLIN_MODEL=local-model-name
NATIVE_PANGOLIN_API_KEY=local-dev-key

# The successful run shape: exactly one model-visible tool, execute_code.
PANGOLIN_SCRATCHPAD=1
PANGOLIN_SCRATCHPAD_MODE=v2
NATIVE_EXEC_FINISH_HELPER=1
NATIVE_EXEC_RUN_HELPER=1

# Keep preflight off. It was faster in some places but caused reference regressions.
NATIVE_PREFLIGHT_CONTEXT=0

# Runtime limits used by the successful Pangolin ECOM dev run.
NATIVE_PANGOLIN_MAX_ITERATIONS=20
NATIVE_PANGOLIN_MAX_OUTPUT_TOKENS=12000
NATIVE_SESSION_TIMEOUT_SEC=1440
NATIVE_LEADERBOARD=0
NATIVE_PARALLELISM=10
